    {
      "cell_type": "code",
      "source": [
        "# Convert infinite growth values to missing\n",
        "panel[\"Growth\"] = panel[\"Growth\"].replace([np.inf, -np.inf], np.nan)\n",
        "\n",
        "# Restrict Leverage to a plausible economic range\n",
        "panel = panel[(panel[\"Leverage\"] >= 0) & (panel[\"Leverage\"] <= 3)].copy()\n",
        "\n",
        "# Winsorize Profitability, Tangibility, and Growth at the 1st and 99th percentiles\n",
        "def winsorize(series, lower=0.01, upper=0.99):\n",
        "    lower_bound = series.quantile(lower)\n",
        "    upper_bound = series.quantile(upper)\n",
        "    return series.clip(lower=lower_bound, upper=upper_bound)\n",
        "\n",
        "panel[\"Profitability\"] = winsorize(panel[\"Profitability\"])\n",
        "panel[\"Tangibility\"] = winsorize(panel[\"Tangibility\"])\n",
        "panel[\"Growth\"] = winsorize(panel[\"Growth\"])\n",
        "\n",
        "print(\"Shape after cleaning:\", panel.shape)\n",
        "print(\"\\nDescriptive statistics after cleaning:\")\n",
        "print(panel[[\"Leverage\", \"Profitability\", \"Tangibility\", \"Size\", \"Growth\"]].describe())"
